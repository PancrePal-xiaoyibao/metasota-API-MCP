# 秘塔搜索 MCP 服务器环境变量配置模板
# 复制此文件为 .env 并填入实际值

# ==================== 必需配置 ====================

# 秘塔搜索 API Key (必填)
# 获取地址: https://metaso.cn/search-api/api-keys
METASO_API_KEY=mk-你的API密钥

# ==================== API 配置 ====================

# API 基础端点 (可选，默认: https://metaso.cn/api/v1)
METASO_BASE_URL=https://metaso.cn/api/v1

# API 请求超时时间，单位：毫秒 (可选，默认: 60000，即60秒)
METASO_TIMEOUT=60000

# ==================== 搜索默认配置 ====================

# 默认搜索范围 (可选，默认: webpage)
# 可选值: webpage, document, paper, image, video, podcast
METASO_DEFAULT_SEARCH_SCOPE=webpage

# 默认搜索结果数量 (可选，默认: 10，范围: 1-100)
METASO_DEFAULT_SEARCH_SIZE=10

# 默认是否通过网页摘要增强召回 (可选，默认: false)
# 开启后可获取综合摘要信息
METASO_DEFAULT_INCLUDE_SUMMARY=false

# 默认是否抓取所有来源网页原文 (可选，默认: false)
# 开启后会抓取并返回网页的完整原文内容
METASO_DEFAULT_INCLUDE_RAW_CONTENT=false

# 默认是否返回精简的原文匹配信息 (可选，默认: false)
METASO_DEFAULT_CONCISE_SNIPPET=false

# ==================== 网页读取默认配置 ====================

# 默认网页读取输出格式 (可选，默认: markdown)
# 可选值: markdown, json
METASO_DEFAULT_READER_FORMAT=markdown
